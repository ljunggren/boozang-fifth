  "heading_pages": "<h1>Build. Test. <span class=\"colored_blue_part\">Automate.</span></h1>\r\nWith Boozang, you can write tests, debug visually, perform root cause analysis and automate your CI builds.",
  "btn_links": "2",
  "btn_links_0_link": "a:3:{s:5:\"title\";s:12:\"Try for Free\";s:3:\"url\";s:39:\"https://ai.boozang.com/#security/signup\";s:6:\"target\";s:0:\"\";}",
  "btn_links_0_btn_color": "green",
  "btn_links_1_link": "a:3:{s:5:\"title\";s:11:\"Book a Demo\";s:3:\"url\";s:28:\"https://calendly.com/boozang\";s:6:\"target\";s:6:\"_blank\";}",
  "btn_links_1_btn_color": "outline_color_white",
  "front_page_blocks_0_background_color": "lighturqoise",
  "front_page_blocks_0_heading": "",
  "front_page_blocks_0_preamble": "",
  "front_page_blocks_0_link_url": "",
  "front_page_blocks_0_img": "5817",
  "front_page_blocks_1_heading": "Boozang works with the tools you depend on",
  "front_page_blocks_1_text": "<h2>Our customers love us</h2>\r\n[trustindex no-registration=capterra]",
  "front_page_blocks_3_heading_background": "blueDarkSolid",
  "front_page_blocks_3_tagline": "Why Boozang?",
  "front_page_blocks_3_heading": "<h2>Browser based. <span class=\"colored_part\"> Codeless testing.</span></h2>",
  "front_page_blocks_3_preamble": "Boozang offers cloud native AI-powered test automation for anything that runs in the browser.",
  "front_page_blocks_3_two_columns_row_0_background_color": "blue",
  "front_page_blocks_3_two_columns_row_0_two_columns_0_img": "5817",
  "front_page_blocks_3_two_columns_row_0_two_columns_1_heading": "Test end-to-end from the browser",
  "front_page_blocks_3_two_columns_row_0_two_columns_1_text": "<h2>Our<span class=\"dark_text\"> model-based </span>approach to testing</h2>\r\nBoozang makes it easy to build powerful and maintainable end-to-end tests using a model-based visual interface. Instead of writing scripts, users create flows by linking test modules that represent UI actions and API calls.\r\n\r\nThis modular approach improves test reusability and allows teams to quickly adapt to changes without rewriting everything. You can visualize your application’s logic and manage test data - all from within your browser.\r\n<ul>\r\n \t<li>Visualize the structure of your application and test flows</li>\r\n \t<li>Create reusable building blocks that scale with your development</li>\r\n \t<li>Maintain stability even in fast-changing, complex systems</li>\r\n</ul>",
  "front_page_blocks_3_two_columns_row_0_two_columns_1_link": "a:3:{s:5:\"title\";s:30:\"More about model-based testing\";s:3:\"url\";s:62:\"https://docs.boozang.com/docs/model-based-testing/introduction\";s:6:\"target\";s:6:\"_blank\";}",
  "front_page_blocks_3_two_columns_row_0_two_columns": "a:2:{i:0;s:3:\"img\";i:1;s:4:\"text\";}",
  "front_page_blocks_3_two_columns_row_1_two_columns_0_heading": "UI and API testing under one roof",
  "front_page_blocks_3_two_columns_row_1_two_columns_0_text": "Boozang is a comprehensive, easy to use, single tool for all of your user interface and API testing needs. Fewer tools with a single reporting dashboard.",
  "front_page_blocks_3_two_columns_row_1_two_columns_0_link": "a:3:{s:5:\"title\";s:10:\"Learn more\";s:3:\"url\";s:24:\"https://docs.boozang.com\";s:6:\"target\";s:6:\"_blank\";}",
  "front_page_blocks_3_two_columns_row_1_two_columns_1_img": "5645",
  "front_page_blocks_3_two_columns_row_2_two_columns_0_img": "5641",
  "front_page_blocks_3_two_columns_row_2_two_columns_1_heading": "Stable natural language selectors",
  "front_page_blocks_3_two_columns_row_2_two_columns_1_text": "Boozang’s NLP selectors make tests resilient to changes by leveraging what’s visible on the page instead of relying on element tags or their attributes.",
  "front_page_blocks_3_two_columns_row_2_two_columns_1_link": "a:3:{s:5:\"title\";s:10:\"Learn more\";s:3:\"url\";s:24:\"https://docs.boozang.com\";s:6:\"target\";s:6:\"_blank\";}",
  "front_page_blocks_3_two_columns_row_3_two_columns_0_heading": "Debug tests on the fly",
  "front_page_blocks_3_two_columns_row_3_two_columns_0_text": "Boozang makes troubleshooting a breeze because you can debug failed tests visually or with built-in developer tools that you know and love.",
  "front_page_blocks_3_two_columns_row_3_two_columns_0_link": "a:3:{s:5:\"title\";s:10:\"Learn more\";s:3:\"url\";s:24:\"https://docs.boozang.com\";s:6:\"target\";s:6:\"_blank\";}",
  "front_page_blocks_3_two_columns_row_3_two_columns_1_img": "5642",
  "front_page_blocks_3_two_columns_row_4_two_columns_0_img": "5640",
  "front_page_blocks_3_two_columns_row_4_two_columns_1_heading": "Cucumber support built in",
  "front_page_blocks_3_two_columns_row_4_two_columns_1_text": "Empower your team to drive tests with business logic written in Gherkin. Boozang integrates directly with Cucumber compatible tools like Xray, JIRA. ",
  "front_page_blocks_3_two_columns_row_4_two_columns_1_link": "a:3:{s:5:\"title\";s:10:\"Learn more\";s:3:\"url\";s:24:\"https://docs.boozang.com\";s:6:\"target\";s:6:\"_blank\";}",
  "front_page_blocks_3_two_columns_row_5_two_columns_0_heading": "Fix root causes not symptoms",
  "front_page_blocks_3_two_columns_row_5_two_columns_0_text": "Get business insights to prioritize your work and improve team output with root cause analysis. Avoid false negatives and increase feature test coverage.",
  "front_page_blocks_3_two_columns_row_5_two_columns_0_link": "a:3:{s:5:\"title\";s:10:\"Learn more\";s:3:\"url\";s:24:\"https://docs.boozang.com\";s:6:\"target\";s:6:\"_blank\";}",
  "front_page_blocks_3_two_columns_row_5_two_columns_1_img": "5643",
  "front_page_blocks_3_two_columns_row_6_two_columns_0_img": "5645",
  "front_page_blocks_3_two_columns_row_6_two_columns_1_heading": "Canvas testing like no other",
  "front_page_blocks_3_two_columns_row_6_two_columns_1_text": "Boozang makes testing on top of HTML canvas simple. Unlike other tools, you can record complex actions like drag & drop and validate them in the canvas.",
