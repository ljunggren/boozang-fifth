  "front_page_blocks_2_heading": "Why choose Boozang for test automation?",
  "front_page_blocks_2_features_presentation": "<h2><span class=\"colored_purple_part\">Browser </span>based.\r\n<span class=\"colored_purple_part\">Codeless </span>testing.</h2>\r\nBoozang offers cloud native AI-powered test automation for anything that runs in the browser.",
  "front_page_blocks_2_read_more_link": "a:3:{s:5:\"title\";s:28:\"Read more about our features\";s:3:\"url\";s:37:\"https://boozang.com/feature-overview/\";s:6:\"target\";s:0:\"\";}",
  "front_page_blocks_2_feature_blocks_row_0_featuretext": "<h3>Test <span class=\"colored_blue_part\">end-to-end</span> from the browser.</h3>\r\nNo Selenium web driver. Write tests the way a user would perform them.",
  "front_page_blocks_2_feature_blocks_row_1_featuretext": "<h3><span class=\"colored_blue_part\">UI and API</span> testing under one roof.</h3>\r\nA single tool for all of your user interface and API testing needs.",
  "front_page_blocks_2_feature_blocks_row": "6",
  "front_page_blocks_2_feature_blocks_row_2_featuretext": "<h3><span class=\"colored_blue_part\">Debug </span>tests on the fly.</h3>\r\nDebug test line by line with built-in developer tools.",
  "front_page_blocks_2_feature_blocks_row_3_featuretext": "<h3>Stable <span class=\"colored_blue_part\">natural language </span>selectors.</h3>\r\nLess flaky than Xpath or CSS selectors.",
  "front_page_blocks_2_feature_blocks_row_4_featuretext": "<h3>Fix <span class=\"colored_blue_part\">root causes</span> not symptoms.</h3>\r\nTrack and do root cause analysis easily.",
  "front_page_blocks_2_feature_blocks_row_5_featuretext": "<h3><span class=\"colored_blue_part\">Cucumber </span>support\r\nbuilt-in.</h3>\r\nGurkin support built-in allows interation to tools such as Xray/Jira.",
